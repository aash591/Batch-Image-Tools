# Main settings
TARGET_RESOLUTIONS=1440x3216,1440x3168,1240x2772,1080x2520,1080x2408,1080x2400,1080x2340,1080x2280,1080x2160,720x1612,1080x1920

# Optional folder naming
OUTPUT_FOLDER_LABELS=3216x1440,3168x1440,2772x1240,2520x1080,2408x1080,2400x1080,2340x1080,2280x1080,2160x1080,1612x720,1920x1080
OUTPUT_FOLDER_PREFIX=drawable-xxhdpi-

INPUT_DIR=input
OUTPUT_DIR=resize_output

# Quality: 1-100
QUALITY=90

# cover | cropping | pad | contain
RESIZE_MODE=pad

# original | jpeg | png | webp
OUTPUT_FORMAT=jpeg





# Optional advanced settings

# true = JPEG loads in multiple passes; usually fine to keep true
JPEG_PROGRESSIVE=true
# 4:4:4 = sharpest text, 4:2:2 = balanced, 4:2:0 = smaller files
JPEG_SUBSAMPLING=4:4:4
# 0 = keep full-color PNG, 2-256 = fewer colors for smaller PNGs
PNG_QUANTIZE_COLORS=0
# Only matters when PNG_QUANTIZE_COLORS is above 0
PNG_DITHER=false
# true = lossless WebP, usually larger files
WEBP_LOSSLESS=false
# Used only when RESIZE_MODE=pad; use R,G,B or transparent
PAD_COLOR=255,255,255
# Used for crop/pad positioning: center | top | bottom | left | right
CROP_ANCHOR=center
