# ─────────────────────────────────────────────
#  Image Resizer Configuration
#  Format: WIDTHxHEIGHT  (comma-separated)
# ─────────────────────────────────────────────

TARGET_RESOLUTIONS=1440x3216,1440x3168,1240x2772,1080x2520,1080x2408,1080x2400,1080x2340,1080x2280,1080x2160,720x1612,1080x1920

# Optional custom folder labels for each target resolution.
# Example: portrait image 1440x3168 can be saved in folder 3168x1440.
OUTPUT_FOLDER_LABELS=3216x1440,3168x1440,2772x1240,2520x1080,2408x1080,2400x1080,2340x1080,2280x1080,2160x1080,1612x720,1920x1080
# Optional prefix for each output folder.
# Example result: drawable-xxhdpi-3168x1440
OUTPUT_FOLDER_PREFIX=drawable-xxhdpi-

INPUT_DIR=input
OUTPUT_DIR=output

# Legacy shared quality fallback (used if format-specific values are not set)
QUALITY=92

# Resize mode:
#   cover   = fill target and crop excess
#   pad     = keep full content and add padding to reach exact size
#   contain = keep full content without padding (output may be smaller)
RESIZE_MODE=pad

# Output format:
#   original = keep the source file type
#   jpeg     = smallest files in most cases, good when slight loss is acceptable
#   png      = best when you need lossless output
#   webp     = usually smaller than PNG, sometimes smaller than JPEG
OUTPUT_FORMAT=jpeg

# JPEG compression settings
JPEG_QUALITY=90
JPEG_PROGRESSIVE=true
JPEG_SUBSAMPLING=4:4:4  #For Text sharpening

# PNG compression settings
PNG_COMPRESS_LEVEL=9
PNG_QUANTIZE_COLORS=0
PNG_DITHER=false

# WebP compression settings
WEBP_QUALITY=90
WEBP_METHOD=6
WEBP_LOSSLESS=false

# Padding color for RESIZE_MODE=pad.
# Format: R,G,B   Example: 255,255,255
PAD_COLOR=255,255,255

# Anchor: center | top | bottom | left | right
CROP_ANCHOR=center
